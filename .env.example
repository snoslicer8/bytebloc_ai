# ByteBloc API Credentials

# The following are examples of how to set up your API credentials

BYTEBLOC_API_KEY=your_api_key_here
BYTEBLOC_API_SECRET=your_api_secret_here

# Database Settings

# Example configuration for connecting to the database
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=your_database_name

# AI Model Configuration

# Example settings for configuring the AI model
AI_MODEL_NAME=your_model_name_here
AI_MODEL_VERSION=1.0
AI_MODEL_ENDPOINT=http://api.yourdomain.com/model
